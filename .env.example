# Supabase — copy this file to .env.local and fill in your values
# These will be populated when Supabase project is created

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public website origin (e.g. https://kerimebalabanakademi.com) — used when
# building share links in mobile apps where window.location.origin is a
# capacitor:// scheme that can't be opened externally. Leave unset for web
# builds; window.location.origin is used as fallback.
VITE_PUBLIC_SITE_URL=
